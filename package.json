{
  "name": "feature-flag-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "syntax": "tsc --noEmit",
    "check": "pnpm syntax && pnpm format && pnpm lint && pnpm typecheck && pnpm knip",
    "knip": "knip",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "test:evaluation-core": "pnpm --filter @feature-flag-platform/evaluation-core test",
    "dev:web": "pnpm --filter @feature-flag-platform/web dev",
    "dev:api": "pnpm --filter @feature-flag-platform/api dev",
    "dev:worker": "pnpm --filter @feature-flag-platform/worker dev",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down",
    "db:logs": "docker compose -f infra/docker/docker-compose.yml logs -f",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/seed.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.7",
    "knip": "^6.1.0",
    "pg": "^8.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
